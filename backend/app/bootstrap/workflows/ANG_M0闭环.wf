# 工作流：ANG_M0闭环
# 功能：按 M0 闭环串联 AI_NovelGenerator 提示词，生成架构五步、分卷、章节目录、章节正文草稿
# 触发器：无（手动执行）

#@node(description="选择项目")
project = Logic.SelectProject(project_id=1, project_name=None)
#</node>


#@node(description="选择模型")
llm = Logic.SelectLLM(llm_config_id=1, llm_name=None)
#</node>


#@node(description="查询项目作品标签（用于类型与主题）")
tags_cards = Card.Query(
    project_id=project.project_id,
    card_type="作品标签",
    limit=1
  )
#</node>


#@node(description="查询项目写作指南（用于用户指导）")
writing_guide_cards = Card.Query(
    project_id=project.project_id,
    card_type="写作指南",
    limit=1
  )
#</node>


#@node(description="构建基础输入参数")
base = Logic.Expression(
    expression="{'genre': str(((tags_cards.cards[0].content if tags_cards.cards else {}) or {}).get('genre') or '玄幻'), 'topic': str(((tags_cards.cards[0].content if tags_cards.cards else {}) or {}).get('topic') or ((tags_cards.cards[0].content if tags_cards.cards else {}) or {}).get('core_theme') or '成长与抉择'), 'Total_volume_number': int(((tags_cards.cards[0].content if tags_cards.cards else {}) or {}).get('total_volume_number') or ((tags_cards.cards[0].content if tags_cards.cards else {}) or {}).get('volume_count') or 3), 'number_of_chapters': int(((tags_cards.cards[0].content if tags_cards.cards else {}) or {}).get('number_of_chapters') or ((tags_cards.cards[0].content if tags_cards.cards else {}) or {}).get('total_chapters') or 60), 'word_number': int(((tags_cards.cards[0].content if tags_cards.cards else {}) or {}).get('word_number') or ((tags_cards.cards[0].content if tags_cards.cards else {}) or {}).get('chapter_word_count') or 3000), 'user_guidance': str(((writing_guide_cards.cards[0].content if writing_guide_cards.cards else {}) or {}).get('content') or ((writing_guide_cards.cards[0].content if writing_guide_cards.cards else {}) or {}).get('guide') or '')}"
  )
#</node>


#@node(description="选择目标卷号（M0 固定首卷）")
volume_number = Logic.Expression(
    expression="1"
  )
#</node>


#@node(description="计算首卷章节范围")
volume_range = Logic.Expression(
    expression="{'x': 1, 'y': max(1, (base.result.number_of_chapters + max(1, base.result.Total_volume_number) - 1) // max(1, base.result.Total_volume_number))}"
  )
#</node>


#@node(description="加载提示词：架构步骤1")
step1_prompt = Prompt.Load(
    prompt_id="ANG.M0.architecture_step1_mission",
    variables={
      "genre": "$base.result.genre",
      "Total_volume_number": "$base.result.Total_volume_number",
      "number_of_chapters": "$base.result.number_of_chapters",
      "word_number": "$base.result.word_number",
      "topic": "$base.result.topic",
      "user_guidance": "$base.result.user_guidance"
    }
  )
#</node>


#@node(description="执行生成：架构步骤1")
step1_ai = AI.LLM(
    llm_config_id=llm.llm_config_id,
    user_prompt=step1_prompt.text,
    temperature=0.7,
    max_tokens=8192,
    timeout=150,
    max_retry=3
  )
#</node>


#@node(description="保存结果：架构步骤1")
step1_card = Card.Create(
    project_id=project.project_id,
    card_type="通用文本",
    title="ANG.M0/架构步骤1-分卷使命",
    content={"content": step1_ai.response}
  )
#</node>


#@node(description="加载提示词：架构步骤2")
step2_prompt = Prompt.Load(
    prompt_id="ANG.M0.architecture_step2_worldview",
    variables={
      "genre": "$base.result.genre",
      "Total_volume_number": "$base.result.Total_volume_number",
      "number_of_chapters": "$base.result.number_of_chapters",
      "word_number": "$base.result.word_number",
      "topic": "$base.result.topic",
      "user_guidance": "$base.result.user_guidance",
      "step1_result": "$step1_ai.response"
    }
  )
#</node>


#@node(description="执行生成：架构步骤2")
step2_ai = AI.LLM(
    llm_config_id=llm.llm_config_id,
    user_prompt=step2_prompt.text,
    temperature=0.7,
    max_tokens=8192,
    timeout=150,
    max_retry=3
  )
#</node>


#@node(description="保存结果：架构步骤2")
step2_card = Card.Create(
    project_id=project.project_id,
    card_type="通用文本",
    title="ANG.M0/架构步骤2-世界观冲突",
    content={"content": step2_ai.response}
  )
#</node>


#@node(description="加载提示词：架构步骤3")
step3_prompt = Prompt.Load(
    prompt_id="ANG.M0.architecture_step3_plot",
    variables={
      "genre": "$base.result.genre",
      "Total_volume_number": "$base.result.Total_volume_number",
      "number_of_chapters": "$base.result.number_of_chapters",
      "word_number": "$base.result.word_number",
      "topic": "$base.result.topic",
      "user_guidance": "$base.result.user_guidance",
      "step1_result": "$step1_ai.response",
      "step2_result": "$step2_ai.response"
    }
  )
#</node>


#@node(description="执行生成：架构步骤3")
step3_ai = AI.LLM(
    llm_config_id=llm.llm_config_id,
    user_prompt=step3_prompt.text,
    temperature=0.7,
    max_tokens=8192,
    timeout=150,
    max_retry=3
  )
#</node>


#@node(description="保存结果：架构步骤3")
step3_card = Card.Create(
    project_id=project.project_id,
    card_type="通用文本",
    title="ANG.M0/架构步骤3-情节线",
    content={"content": step3_ai.response}
  )
#</node>


#@node(description="加载提示词：架构步骤4")
step4_prompt = Prompt.Load(
    prompt_id="ANG.M0.architecture_step4_character",
    variables={
      "genre": "$base.result.genre",
      "Total_volume_number": "$base.result.Total_volume_number",
      "number_of_chapters": "$base.result.number_of_chapters",
      "word_number": "$base.result.word_number",
      "topic": "$base.result.topic",
      "user_guidance": "$base.result.user_guidance",
      "step1_result": "$step1_ai.response",
      "step2_result": "$step2_ai.response",
      "step3_result": "$step3_ai.response"
    }
  )
#</node>


#@node(description="执行生成：架构步骤4")
step4_ai = AI.LLM(
    llm_config_id=llm.llm_config_id,
    user_prompt=step4_prompt.text,
    temperature=0.7,
    max_tokens=8192,
    timeout=150,
    max_retry=3
  )
#</node>


#@node(description="保存结果：架构步骤4")
step4_card = Card.Create(
    project_id=project.project_id,
    card_type="通用文本",
    title="ANG.M0/架构步骤4-核心角色规划",
    content={"content": step4_ai.response}
  )
#</node>


#@node(description="加载提示词：架构步骤5")
step5_prompt = Prompt.Load(
    prompt_id="ANG.M0.architecture_step5_style",
    variables={
      "genre": "$base.result.genre",
      "Total_volume_number": "$base.result.Total_volume_number",
      "number_of_chapters": "$base.result.number_of_chapters",
      "word_number": "$base.result.word_number",
      "topic": "$base.result.topic",
      "user_guidance": "$base.result.user_guidance",
      "step1_result": "$step1_ai.response",
      "step2_result": "$step2_ai.response",
      "step3_result": "$step3_ai.response",
      "step4_result": "$step4_ai.response"
    }
  )
#</node>


#@node(description="执行生成：架构步骤5")
step5_ai = AI.LLM(
    llm_config_id=llm.llm_config_id,
    user_prompt=step5_prompt.text,
    temperature=0.7,
    max_tokens=8192,
    timeout=150,
    max_retry=3
  )
#</node>


#@node(description="保存结果：架构步骤5")
step5_card = Card.Create(
    project_id=project.project_id,
    card_type="通用文本",
    title="ANG.M0/架构步骤5-叙事规划",
    content={"content": step5_ai.response}
  )
#</node>


#@node(description="加载提示词：首卷分卷格式模板")
volume_design_format_prompt = Prompt.Load(
    prompt_id="ANG.M0.volume_design_format",
    variables={
      "volume_number": "$volume_number.result"
    }
  )
#</node>


#@node(description="加载提示词：首卷分卷大纲")
volume_outline_prompt = Prompt.Load(
    prompt_id="ANG.M0.volume_outline",
    variables={
      "volume_number": "$volume_number.result",
      "genre": "$base.result.genre",
      "Total_volume_number": "$base.result.Total_volume_number",
      "number_of_chapters": "$base.result.number_of_chapters",
      "word_number": "$base.result.word_number",
      "topic": "$base.result.topic",
      "user_guidance": "$base.result.user_guidance",
      "volume_mission_statement": "$step1_ai.response",
      "worldview_and_conflict": "$step2_ai.response",
      "plotline_and_progression": "$step3_ai.response",
      "core_characters": "$step4_ai.response",
      "narrative_style": "$step5_ai.response",
      "setting_characters": "$step4_ai.response",
      "character_state": "$step4_ai.response",
      "characters_involved": "",
      "volume_design_format": "$volume_design_format_prompt.text"
    }
  )
#</node>


#@node(description="执行生成：首卷分卷大纲")
volume_outline_ai = AI.LLM(
    llm_config_id=llm.llm_config_id,
    user_prompt=volume_outline_prompt.text,
    temperature=0.7,
    max_tokens=8192,
    timeout=150,
    max_retry=3
  )
#</node>


#@node(description="保存结果：分卷大纲")
volume_outline_card = Card.Create(
    project_id=project.project_id,
    card_type="通用文本",
    title="ANG.M0/分卷大纲-第1卷",
    content={"content": volume_outline_ai.response}
  )
#</node>


#@node(description="加载提示词：章节目录")
chapter_blueprint_prompt = Prompt.Load(
    prompt_id="ANG.M0.chapter_blueprint",
    variables={
      "genre": "$base.result.genre",
      "Total_volume_number": "$base.result.Total_volume_number",
      "number_of_chapters": "$base.result.number_of_chapters",
      "word_number": "$base.result.word_number",
      "volume_number": "$volume_number.result",
      "x": "$volume_range.result.x",
      "y": "$volume_range.result.y",
      "user_guidance": "$base.result.user_guidance",
      "chapter_list": "",
      "main_character": "$step4_ai.response",
      "volume_outline": "$volume_outline_ai.response",
      "Foreshadowing_state": "",
      "Foreshadowing_number": "YF000"
    }
  )
#</node>


#@node(description="执行生成：章节目录")
chapter_blueprint_ai = AI.LLM(
    llm_config_id=llm.llm_config_id,
    user_prompt=chapter_blueprint_prompt.text,
    temperature=0.7,
    max_tokens=8192,
    timeout=180,
    max_retry=3
  )
#</node>


#@node(description="保存结果：章节目录")
chapter_blueprint_card = Card.Create(
    project_id=project.project_id,
    card_type="通用文本",
    title="ANG.M0/章节目录-第1卷",
    content={"content": chapter_blueprint_ai.response}
  )
#</node>


#@node(description="提取第一章标题")
chapter_title = Logic.Expression(
    expression="'第1章'"
  )
#</node>


#@node(description="第一章目标字数区间")
chapter_word_bounds = Logic.Expression(
    expression="{'min_words': max(1000, int(base.result.word_number) - 600), 'max_words': int(base.result.word_number) + 600}"
  )
#</node>


#@node(description="加载提示词：第一章正文草稿")
chapter_draft_prompt = Prompt.Load(
    prompt_id="ANG.M0.chapter_draft",
    variables={
      "history_chapter_text": "",
      "genre": "$base.result.genre",
      "topic": "$base.result.topic",
      "novel_number": "1",
      "chapter_title": "$chapter_title.result",
      "word_number": "$base.result.word_number",
      "key_items": "",
      "scene_location": "",
      "time_constraint": "",
      "user_guidance": "$base.result.user_guidance",
      "current_chapter_blueprint": "$chapter_blueprint_ai.response",
      "next_chapter_blueprint": "",
      "volume_outline": "$volume_outline_ai.response",
      "global_summary": "",
      "plot_points": "",
      "setting_characters": "$step4_ai.response",
      "knowledge_context": "",
      "word_count_min": "$chapter_word_bounds.result.min_words",
      "word_count_max": "$chapter_word_bounds.result.max_words"
    }
  )
#</node>


#@node(description="执行生成：第一章正文草稿")
chapter_draft_ai = AI.LLM(
    llm_config_id=llm.llm_config_id,
    user_prompt=chapter_draft_prompt.text,
    temperature=0.75,
    max_tokens=8192,
    timeout=180,
    max_retry=3
  )
#</node>


#@node(description="保存结果：第一章正文草稿")
chapter_draft_card = Card.Create(
    project_id=project.project_id,
    card_type="通用文本",
    title="ANG.M0/章节正文草稿-第1章",
    content={"content": chapter_draft_ai.response}
  )
#</node>
